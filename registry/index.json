    "id": "io.timeplus.market-data",
    "name": "Coinbase Crypto Analytics",
    "version": "1.0.2",
    "author": "Timeplus",
    "description": "Real-time crypto market data from Coinbase WebSocket \u2014 OHLC candlesticks, RSI, order book snapshots, VWAP, and quantitative alpha signals.\n",
    "db_name": "market_data",
    "categories": [
      "analytics",
      "finance"
    ],
    "config": [
      {
        "key": "websocket_url",
        "type": "string",
        "required": false,
        "default": "wss://ws-feed.exchange.coinbase.com",
        "description": "Coinbase WebSocket feed URL"
      },
      {
        "key": "product_ids",
        "type": "list",
        "required": false,
        "default": "[\"BTC-USD\",\"ETH-USD\",\"SOL-USD\"]",
        "description": "Coinbase product IDs to subscribe to. Find valid product IDs at https://docs.cdp.coinbase.com/exchange/reference/exchangerestapi_getproducts or by running: curl https://api.exchange.coinbase.com/products | jq '[.[].id]' Examples: \"BTC-USD\", \"ETH-USD\", \"SOL-USD\", \"XRP-USD\", \"DOGE-USD\"\n"
      }
    ],
    "python_packages": [
      "json5>=0.9.6",
      "websocket-client>=1.4.0"
    ],
    "resources": [
      {
        "file": "ddl/003_coinbase_websocket.sql",
