  {
    "package_format_version": 1,
    "id": "io.timeplus.cisco-asa-ddos",
    "name": "Cisco ASA DDoS Detection Demo",
    "version": "1.0.0",
    "author": "Timeplus",
    "description": "Real-time DDoS detection from simulated Cisco ASA firewall logs. Generates background traffic and a controllable attack stream, parses raw syslog into structured fields, then applies dynamic per-IP baselines (overall and hourly) to detect traffic spikes. Fires a webhook alert when the spike ratio exceeds the configured threshold. Resume and pause the attack MV to control the simulation.\nThe attack MV is paused automatically on install. To trigger the simulated attack:\n  SYSTEM RESUME MATERIALIZED VIEW <db>.mv_asa_logs_sim_attack;\n",
    "db_name": "cisco_asa_ddos",
    "categories": [
      "security",
      "observability",
      "demo"
    ],
    "python_packages": [
      "requests>=2.28.0"
    ],
    "config": [
      {
        "key": "alert_webhook_url",
        "type": "string",
        "required": false,
        "default": "http://localhost/alert",
        "description": "HTTP endpoint that receives DDoS alert POSTs. Payload: {\"title\": \"...\", \"message\": \"...\", \"severity\": \"high\"}.\n"
      },
      {
        "key": "spike_threshold",
        "type": "integer",
        "required": false,
        "default": "10",
        "description": "Spike ratio multiplier that triggers an alert. An IP is flagged when its live traffic exceeds this multiple of its baseline.\n"
      },
      {
        "key": "attacker_src_ip",
        "type": "string",
        "required": false,
        "default": "203.0.113.67",
        "description": "Source IP used by the simulated attacker for baseline and attack traffic."
      },
      {
        "key": "background_eps",
        "type": "integer",
        "required": false,
        "default": "100",
        "description": "Events per second for the background traffic generator (many random IPs)."
      },
      {
        "key": "sim_normal_eps",
        "type": "integer",
        "required": false,
        "default": "5",
        "description": "Events per second for the attacker IP normal baseline traffic."
      },
      {
        "key": "sim_attack_eps",
        "type": "integer",
        "required": false,
        "default": "500",
        "description": "Events per second for the attack traffic burst (used when attack MV is resumed)."
      },
      {
        "key": "retention_hours",
        "type": "integer",
        "required": false,
        "default": "4",
        "description": "Stream TTL in hours. Data older than this is automatically dropped."
      },
      {
        "key": "logstore_retention_bytes",
        "type": "integer",
        "required": false,
        "default": "107374182",
        "description": "Maximum logstore size per stream in bytes (default ~100 MB)."
